          className={`flex flex-col items-center gap-1 transition-all duration-300 w-16 ${activeTab === 'metronome' ? 'text-[#ffcc00] scale-110' : 'text-gray-600 hover:text-gray-400'}`}
        >
          <Music size={20} strokeWidth={activeTab === 'metronome' ? 2.5 : 2} />
