        {activeTab === 'tuner' ? <Tuner /> : <Metronome />}
      </div>

      {/* 하단 네비게이션 탭 */}
      <div className="absolute bottom-0 w-full max-w-md bg-black/95 backdrop-blur-md border-t border-gray-900 pb-safe pb-3 pt-2.5 px-8 flex justify-around z-50 shadow-[0_-10px_40px_rgba(0,0,0,0.8)]">
        <button 
          onClick={() => setActiveTab('tuner')}
          className={`flex flex-col items-center gap-1 transition-all duration-300 w-16 ${activeTab === 'tuner' ? 'text-[#4afc9d] scale-110' : 'text-gray-600 hover:text-gray-400'}`}
        >
